{
  "name": "famframe-admin-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test:capture": "node ../scripts/test-capture-parser.js",
    "publish:preview": "vite build && node ../scripts/sync-admin-preview.js",
    "verify": "tsc --noEmit && node ../scripts/test-capture-parser.js && vite build && node ../scripts/verify-admin-preview.js",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "npm:@rollup/wasm-node@^4.60.3",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
